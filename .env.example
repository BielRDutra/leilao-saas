# .env.example
# Copie para .env e ajuste os valores antes de rodar o docker compose.
# NUNCA commite o arquivo .env no Git.

# ── Banco de dados ─────────────────────────────────────────────
DB_PASSWORD=leilao_dev_123

# ── pgAdmin (interface web — só com --profile tools) ──────────
PGADMIN_EMAIL=admin@leilao.com
PGADMIN_PASSWORD=admin123

# ── Score (opcional — sobrescreve o application.properties) ───
# LEILAO_SCORE_PESO_DESCONTO=0.40
# LEILAO_SCORE_PESO_FINANCIAMENTO=0.25
# LEILAO_SCORE_PESO_LOCALIZACAO=0.20
# LEILAO_SCORE_PESO_RISCO=0.15

# ── Scraper ────────────────────────────────────────────────────
# LEILAO_SCRAPER_CRON=0 0 9 * * *

# ── E-mail (SMTP) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_REMETENTE=noreply@leilaosmrt.com

# ── WhatsApp (Z-API) ───────────────────────────────────────────
ZAPI_INSTANCE_ID=SUA_INSTANCIA
ZAPI_TOKEN=SEU_TOKEN
ZAPI_SECURITY_TOKEN=SEU_SECURITY_TOKEN

# ── Front-end (para links nos alertas) ────────────────────────
FRONTEND_URL=http://localhost:3000
